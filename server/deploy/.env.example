# ============================================================
#  饭堂订餐系统 - 部署配置模板
#  复制本文件为 .env 并按实际情况填写：cp .env.example .env
#  .env 含密钥，切勿提交到 git（已在 .gitignore 忽略）
# ============================================================

# ---- 对外访问地址（你单位的公网域名，微信小程序要求 HTTPS）----
# 例：https://canteen.your-company.com/   结尾带斜杠
BASE_PATH=https://canteen.your-company.com/
APP_PATH=https://canteen.your-company.com/

# ---- 后端对外端口（宿主机端口，反向代理/HTTPS 指向它）----
APP_PORT=8088

# ---- 数据库（root 密码，自定义一个强密码）----
DB_NAME=baocan
DB_PASSWORD=please_change_this_db_password

# ---- Redis 密码（可留空表示不加密；公网务必设密码）----
REDIS_PASSWORD=please_change_this_redis_password

# ---- 微信小程序（在 mp.weixin.qq.com 后台 -> 开发管理 -> 开发设置 获取）----
WX_APPID=wxxxxxxxxxxxxxxxxx
WX_SECRET=your_miniapp_secret
# 下面两项仅用到微信消息推送时才需要，否则留空
WX_TOKEN=
WX_AESKEY=

# ---- Druid 数据库监控台登录（/druid/）----
DRUID_USER=admin
DRUID_PASSWORD=please_change_this_druid_password

# ---- Web 后台管理员账号（登录管理后台用，务必改强密码）----
# 后台 appid 自动复用上面的 WX_APPID，无需单独填。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=please_change_this_admin_password
# 单位名称，显示在后台标题栏
ADMIN_UNIT_NAME=饭堂报餐管理后台
